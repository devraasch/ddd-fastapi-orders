APP_NAME=fastapi-ordering-ddd
APP_ENV=development
APP_PORT=8000

POSTGRES_DB=CHANGE_ME
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_PORT=CHANGE_ME

# Quando a API corre no host (fora do Compose) com db publicado na porta acima:
DATABASE_URL=postgresql+asyncpg://CHANGE_ME:CHANGE_ME@127.0.0.1:CHANGE_ME/CHANGE_ME

# Credenciais da fila (também usadas pelo serviço rabbitmq no docker-compose).
# O utilizador predefinido guest do RabbitMQ só aceita ligações de localhost;
# entre contentores é obrigatório outro utilizador (o compose injeta estes valores).
RABBITMQ_USER=CHANGE_ME
RABBITMQ_PASSWORD=CHANGE_ME
# Com a API no host e a porta publicada:
RABBITMQ_URL=amqp://CHANGE_ME:CHANGE_ME@127.0.0.1:CHANGE_ME/

RABBITMQ_PORT=CHANGE_ME
RABBITMQ_MANAGEMENT_PORT=CHANGE_ME
