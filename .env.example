# Copie para .env e ajuste os valores.
# cp .env.example .env

# Aplicação
APP_NAME=fastapi-ordering-ddd
APP_ENV=development
APP_PORT=8000

# PostgreSQL (Compose: serviço típico "db"; API na máquina: use 127.0.0.1 na DATABASE_URL)
POSTGRES_DB=ordering
POSTGRES_USER=ordering_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_PORT=5432

# URL do SQLAlchemy / Alembic (ex.: dentro do Docker com serviço "db")
DATABASE_URL=postgresql+psycopg://ordering_user:CHANGE_ME@db:5432/ordering
# Exemplo com API no host e Postgres exposto: postgresql+psycopg://ordering_user:CHANGE_ME@127.0.0.1:5432/ordering

# RabbitMQ (Compose: hostname "rabbitmq"; guest só para dev local)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
